# Supabase (Edge Function runtime provides SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY automatically)
SUPABASE_URL=https://lxpqnlrdnsmzhvnfrgwl.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Google Drive — paste full JSON of the service account key file
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"backup@project.iam.gserviceaccount.com"}

# Resend.com email (free tier: 3000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Backup notification recipient
BACKUP_EMAIL_TO=sirabdiali@gmail.com

# Optional: secret for CLI-triggered backups
BACKUP_ADMIN_SECRET=change-me-strong-random-string
