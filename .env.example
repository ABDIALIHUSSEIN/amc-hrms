# ============================================================
# AMC HRMS — environment variables (copy to .env, never commit .env)
# ============================================================

# Supabase management PAT — used ONLY by local tooling (.mcp.json), NOT the browser app.
# Full-access token: can read/write/delete the entire Supabase project.
# Get it from: Supabase Dashboard → Account → Access Tokens
# Set in your shell before launching:  export SUPABASE_ACCESS_TOKEN=sbp_xxx
SUPABASE_ACCESS_TOKEN=sbp_REPLACE_WITH_A_FRESHLY_ROTATED_TOKEN

# Browser-facing values (safe to ship to the client — these are in supabase.js).
# The publishable key is public by design; security depends on Row Level Security,
# NOT on hiding this key. See supabase_schema.sql for RLS policies.
SUPABASE_URL=https://lxpqnlrdnsmzhvnfrgwl.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
